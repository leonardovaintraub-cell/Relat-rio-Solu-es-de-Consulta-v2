<html lang="pt-BR"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Portal SC/RFB — Soluções de Consulta</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&amp;family=DM+Sans:wght@300;400;500;600&amp;display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --navy-900: #05101f; --navy-800: #0a1c35; --navy-700: #0f2548;
    --gold-400: #c9a84c; --gold-300: #ddb96a; --gold-200: #edd494;
    --text-primary: #e8e2d0; --text-secondary: #9fa8b8; --text-muted: #5a6477;
    --border: rgba(201,168,76,0.18); --border-strong: rgba(201,168,76,0.35);
    --card-bg: rgba(10,28,53,0.85); --card-hover: rgba(14,36,66,0.95);
    --sidebar-w: 280px; --radius: 10px;
    --transition: 0.25s cubic-bezier(0.4,0,0.2,1);
  }
  html { scroll-behavior: smooth; }
  body { font-family: 'DM Sans', sans-serif; background: var(--navy-900); color: var(--text-primary); min-height: 100vh; overflow-x: hidden; }
  body::before { content: ''; position: fixed; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.045'/%3E%3C/svg%3E"); pointer-events: none; z-index: 0; }
  body::after { content: ''; position: fixed; inset: 0; background: radial-gradient(ellipse 80% 60% at 10% 20%, rgba(30,64,128,0.45) 0%, transparent 60%), radial-gradient(ellipse 60% 80% at 90% 80%, rgba(10,37,72,0.5) 0%, transparent 60%); pointer-events: none; z-index: 0; }
  .app { position: relative; z-index: 1; display: flex; flex-direction: column; min-height: 100vh; }

  /* HEADER */
  header { border-bottom: 1px solid var(--border); background: rgba(5,16,31,0.9); backdrop-filter: blur(12px); padding: 0 2.5rem; position: sticky; top: 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; height: 72px; animation: slideDown 0.6s ease both; }
  @keyframes slideDown { from { transform: translateY(-100%); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  .header-brand { display: flex; align-items: baseline; gap: 0.75rem; }
  .header-brand h1 { font-family: 'Playfair Display', serif; font-size: 1.45rem; font-weight: 700; color: var(--gold-300); }
  .header-brand h1 span { color: var(--text-primary); }
  .header-sub { font-size: 0.72rem; color: var(--text-muted); letter-spacing: 0.08em; text-transform: uppercase; border-left: 1px solid var(--border-strong); padding-left: 0.75rem; }
  .header-actions { display: flex; align-items: center; gap: 0.65rem; flex-wrap: wrap; }
  .btn-add { background: linear-gradient(135deg, var(--gold-400), var(--gold-300)); color: var(--navy-900); border: none; cursor: pointer; padding: 0.5rem 1.1rem; border-radius: 6px; font-family: 'DM Sans', sans-serif; font-size: 0.82rem; font-weight: 600; transition: var(--transition); }
  .btn-add:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(201,168,76,0.3); }
  .btn-header { background: rgba(255,255,255,0.05); border: 1px solid var(--border-strong); color: var(--gold-300); cursor: pointer; padding: 0.45rem 0.9rem; border-radius: 6px; font-family: 'DM Sans', sans-serif; font-size: 0.79rem; font-weight: 500; transition: var(--transition); display: flex; align-items: center; gap: 0.4rem; white-space: nowrap; }
  .btn-header:hover { background: rgba(201,168,76,0.1); border-color: var(--gold-400); }
  .btn-header.export { color: #7ed6a0; border-color: rgba(52,168,100,0.4); }
  .btn-header.export:hover { background: rgba(52,168,100,0.1); border-color: rgba(52,168,100,0.7); }
  #total-badge { font-size: 0.72rem; color: var(--text-muted); background: rgba(255,255,255,0.05); border: 1px solid var(--border); padding: 0.3rem 0.7rem; border-radius: 20px; }
  #total-badge strong { color: var(--gold-300); }

  /* LAYOUT */
  .main-body { display: flex; flex: 1; }

  /* SIDEBAR */
  aside { width: var(--sidebar-w); flex-shrink: 0; border-right: 1px solid var(--border); background: rgba(5,16,31,0.6); backdrop-filter: blur(8px); padding: 2rem 0; position: sticky; top: 72px; height: calc(100vh - 72px); overflow-y: auto; display: flex; flex-direction: column; gap: 2rem; animation: fadeIn 0.7s 0.2s ease both; }
  aside::-webkit-scrollbar { width: 4px; }
  aside::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 4px; }
  .sidebar-section { padding: 0 1.5rem; }
  .sidebar-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold-400); margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
  .sidebar-label::after { content: ''; flex: 1; height: 1px; background: var(--border); }
  .month-pills { display: flex; flex-direction: column; gap: 0.3rem; }
  .pill { padding: 0.45rem 0.85rem; border-radius: 6px; font-size: 0.82rem; cursor: pointer; transition: var(--transition); border: 1px solid transparent; background: transparent; color: var(--text-secondary); text-align: left; font-family: 'DM Sans', sans-serif; display: flex; justify-content: space-between; align-items: center; }
  .pill:hover { background: rgba(201,168,76,0.08); color: var(--text-primary); }
  .pill.active { background: rgba(201,168,76,0.15); border-color: var(--border-strong); color: var(--gold-300); font-weight: 500; }
  .pill .count { font-size: 0.7rem; background: rgba(201,168,76,0.15); color: var(--gold-400); padding: 0.1rem 0.4rem; border-radius: 10px; }
  .subject-list { display: flex; flex-direction: column; gap: 0.2rem; }
  .subject-item { padding: 0.4rem 0.85rem; border-radius: 6px; font-size: 0.8rem; cursor: pointer; transition: var(--transition); border-left: 2px solid transparent; color: var(--text-secondary); background: transparent; text-align: left; font-family: 'DM Sans', sans-serif; line-height: 1.4; display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem; }
  .subject-item:hover { color: var(--text-primary); background: rgba(255,255,255,0.03); }
  .subject-item.active { border-left-color: var(--gold-400); color: var(--gold-300); background: rgba(201,168,76,0.06); font-weight: 500; }
  .subject-item .count { font-size: 0.68rem; background: rgba(201,168,76,0.12); color: var(--gold-400); padding: 0.1rem 0.4rem; border-radius: 10px; flex-shrink: 0; }

  /* MAIN */
  main { flex: 1; padding: 2.5rem 2.5rem 4rem; animation: fadeIn 0.7s 0.1s ease both; min-width: 0; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  /* INDEX PANEL */
  .index-panel { background: rgba(10,28,53,0.7); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem 1.75rem; margin-bottom: 2rem; backdrop-filter: blur(8px); }
  .index-panel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem; }
  .index-panel-title { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 600; color: var(--gold-300); display: flex; align-items: center; gap: 0.6rem; }
  .index-panel-title::before { content: '§'; opacity: 0.7; }
  .index-clear-btn { font-size: 0.75rem; color: var(--text-muted); background: rgba(201,168,76,0.08); border: 1px solid var(--border); padding: 0.3rem 0.8rem; border-radius: 20px; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: var(--transition); display: none; }
  .index-clear-btn.visible { display: block; }
  .index-clear-btn:hover { color: var(--gold-300); border-color: var(--border-strong); }
  .index-tags { display: flex; flex-wrap: wrap; gap: 0.65rem; }
  .index-tag { padding: 0.45rem 1rem; border-radius: 20px; font-size: 0.8rem; cursor: pointer; transition: var(--transition); border: 1px solid var(--border-strong); color: var(--text-secondary); background: rgba(255,255,255,0.03); font-family: 'DM Sans', sans-serif; display: flex; align-items: center; gap: 0.5rem; white-space: nowrap; }
  .index-tag:hover { background: rgba(201,168,76,0.1); color: var(--text-primary); border-color: var(--gold-400); transform: translateY(-1px); }
  .index-tag.active { background: rgba(201,168,76,0.2); color: var(--gold-200); border-color: var(--gold-400); font-weight: 600; box-shadow: 0 4px 16px rgba(201,168,76,0.15); }
  .index-tag .tag-count { font-size: 0.68rem; background: rgba(201,168,76,0.2); color: var(--gold-400); padding: 0.1rem 0.45rem; border-radius: 10px; font-weight: 700; }
  .index-tag.active .tag-count { background: rgba(201,168,76,0.4); }
  .index-empty { font-size: 0.83rem; color: var(--text-muted); font-style: italic; }

  /* SEARCH */
  .search-bar-wrap { margin-bottom: 1.5rem; position: relative; }
  .search-bar { width: 100%; background: rgba(255,255,255,0.04); border: 1px solid var(--border); color: var(--text-primary); padding: 0.75rem 1rem 0.75rem 2.8rem; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-size: 0.9rem; transition: var(--transition); outline: none; }
  .search-bar:focus { border-color: var(--border-strong); background: rgba(255,255,255,0.06); }
  .search-bar::placeholder { color: var(--text-muted); }
  .search-icon { position: absolute; left: 0.9rem; top: 50%; transform: translateY(-50%); color: var(--text-muted); pointer-events: none; }

  /* SECTION HEADING */
  .section-heading { display: flex; align-items: baseline; gap: 1rem; margin-bottom: 1.5rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--border); }
  .section-heading h2 { font-family: 'Playfair Display', serif; font-size: 1.25rem; font-weight: 600; }
  .filter-tag { font-size: 0.75rem; color: var(--gold-400); background: rgba(201,168,76,0.1); border: 1px solid var(--border-strong); padding: 0.2rem 0.6rem; border-radius: 20px; }
  .result-count { font-size: 0.8rem; color: var(--text-muted); margin-left: auto; }

  /* CARDS */
  .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 1.25rem; }
  .card { background: var(--card-bg); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; backdrop-filter: blur(10px); transition: var(--transition); display: flex; flex-direction: column; gap: 1rem; animation: cardIn 0.4s ease both; position: relative; overflow: hidden; }
  .card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--gold-400), transparent); opacity: 0; transition: var(--transition); }
  .card:hover { background: var(--card-hover); border-color: var(--border-strong); transform: translateY(-2px); box-shadow: 0 12px 40px rgba(0,0,0,0.4); }
  .card:hover::before { opacity: 1; }
  @keyframes cardIn { from { opacity: 0; transform: translateY(16px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
  .card-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 0.75rem; }
  .card-number { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; color: var(--gold-300); line-height: 1.2; }
  .card-number span { font-size: 0.72rem; font-family: 'DM Sans', sans-serif; color: var(--text-muted); font-weight: 400; display: block; margin-top: 0.2rem; }
  .card-badge { font-size: 0.68rem; font-weight: 600; padding: 0.3rem 0.65rem; border-radius: 20px; flex-shrink: 0; background: rgba(201,168,76,0.12); color: var(--gold-300); border: 1px solid rgba(201,168,76,0.25); cursor: pointer; transition: var(--transition); white-space: nowrap; }
  .card-badge:hover { background: rgba(201,168,76,0.25); }
  .card-ementa { font-size: 0.82rem; color: var(--text-secondary); line-height: 1.6; font-style: italic; border-left: 2px solid var(--border-strong); padding-left: 0.85rem; margin: 0; }
  .card-ementa.collapsed { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .toggle-ementa { font-size: 0.72rem; color: var(--gold-400); cursor: pointer; background: none; border: none; font-family: 'DM Sans', sans-serif; padding: 0; transition: var(--transition); }
  .toggle-ementa:hover { color: var(--gold-200); }
  .card-divider { height: 1px; background: var(--border); }
  .card-resumo-label { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.4rem; }
  .card-resumo { font-size: 0.84rem; line-height: 1.7; }
  .card-footer { display: flex; justify-content: space-between; align-items: center; gap: 0.5rem; }
  .card-footer-left { display: flex; align-items: center; gap: 0.5rem; }
  .card-footer-right { display: flex; align-items: center; gap: 0.4rem; }
  .btn-card-action { font-size: 0.72rem; color: var(--text-muted); background: none; border: none; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: var(--transition); padding: 0.25rem 0.5rem; border-radius: 4px; display: flex; align-items: center; gap: 0.3rem; }
  .btn-card-action:hover { color: var(--text-primary); background: rgba(255,255,255,0.06); }
  .btn-card-action.danger:hover { color: #e07070; background: rgba(224,112,112,0.08); }
  .btn-card-action.edit:hover { color: var(--gold-300); background: rgba(201,168,76,0.08); }
  .card-pdf-link { display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.72rem; color: var(--gold-400); text-decoration: none; border: 1px solid var(--border-strong); padding: 0.25rem 0.65rem; border-radius: 20px; transition: var(--transition); background: rgba(201,168,76,0.07); }
  .card-pdf-link:hover { background: rgba(201,168,76,0.15); color: var(--gold-200); }

  /* EMPTY */
  .empty-state { text-align: center; padding: 5rem 2rem; grid-column: 1/-1; }
  .empty-state .icon { font-size: 3rem; margin-bottom: 1.5rem; opacity: 0.4; }
  .empty-state h3 { font-family: 'Playfair Display', serif; font-size: 1.3rem; color: var(--text-secondary); margin-bottom: 0.5rem; }
  .empty-state p { font-size: 0.85rem; color: var(--text-muted); line-height: 1.6; }

  /* MODALS */
  .modal-overlay { position: fixed; inset: 0; background: rgba(5,16,31,0.87); backdrop-filter: blur(8px); z-index: 200; display: flex; align-items: flex-start; justify-content: center; padding: 2rem; overflow-y: auto; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
  .modal-overlay.open { opacity: 1; pointer-events: all; }
  .modal { background: var(--navy-800); border: 1px solid var(--border-strong); border-radius: 14px; width: 100%; max-width: 680px; padding: 2.5rem; position: relative; transform: translateY(24px); transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1); box-shadow: 0 40px 80px rgba(0,0,0,0.5); margin: auto; }
  .modal-overlay.open .modal { transform: translateY(0); }
  .modal-sm { max-width: 500px; }
  .modal-header { margin-bottom: 1.75rem; }
  .modal-header h2 { font-family: 'Playfair Display', serif; font-size: 1.4rem; color: var(--gold-300); margin-bottom: 0.3rem; }
  .modal-header p { font-size: 0.82rem; color: var(--text-muted); line-height: 1.5; }
  .modal-close { position: absolute; top: 1.25rem; right: 1.25rem; background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: var(--text-muted); width: 32px; height: 32px; border-radius: 50%; cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center; transition: var(--transition); }
  .modal-close:hover { color: var(--text-primary); background: rgba(255,255,255,0.1); }
  .form-group { margin-bottom: 1.25rem; }
  .form-group label { display: block; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-muted); margin-bottom: 0.5rem; }
  .form-group input, .form-group textarea { width: 100%; background: rgba(255,255,255,0.04); border: 1px solid var(--border); color: var(--text-primary); padding: 0.65rem 0.9rem; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-size: 0.88rem; transition: var(--transition); outline: none; resize: vertical; }
  .form-group input:focus, .form-group textarea:focus { border-color: var(--border-strong); background: rgba(255,255,255,0.06); }
  .form-group input::placeholder, .form-group textarea::placeholder { color: var(--text-muted); }
  .form-group textarea { min-height: 90px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .accordion-section { margin-bottom: 1.5rem; }
  .accordion-trigger { width: 100%; display: flex; justify-content: space-between; align-items: center; background: rgba(201,168,76,0.07); border: 1px solid var(--border); border-radius: 8px; padding: 0.75rem 1rem; cursor: pointer; color: var(--text-primary); font-family: 'DM Sans', sans-serif; font-size: 0.88rem; transition: var(--transition); }
  .accordion-trigger:hover { background: rgba(201,168,76,0.12); }
  .accordion-trigger .arrow { transition: transform 0.3s ease; color: var(--gold-400); }
  .accordion-trigger.open .arrow { transform: rotate(180deg); }
  .accordion-body { overflow: hidden; transition: max-height 0.35s ease, opacity 0.3s ease; max-height: 0; opacity: 0; }
  .accordion-body.open { max-height: 200px; opacity: 1; }
  .accordion-inner { padding-top: 1rem; }
  .api-key-field { display: flex; gap: 0.5rem; }
  .api-key-field input { flex: 1; }
  .btn-eye { background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: var(--text-muted); padding: 0 0.75rem; border-radius: 8px; cursor: pointer; transition: var(--transition); }
  .btn-eye:hover { color: var(--text-primary); }
  .pdf-upload-zone { border: 2px dashed var(--border-strong); border-radius: 10px; padding: 1.2rem; text-align: center; cursor: pointer; transition: var(--transition); margin-bottom: 1.25rem; background: rgba(201,168,76,0.03); position: relative; }
  .pdf-upload-zone:hover, .pdf-upload-zone.dragover { border-color: var(--gold-400); background: rgba(201,168,76,0.07); }
  .pdf-upload-zone input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
  .pdf-upload-icon { font-size: 1.6rem; margin-bottom: 0.4rem; }
  .pdf-upload-text { font-size: 0.8rem; color: var(--text-muted); }
  .pdf-upload-text strong { color: var(--gold-300); }
  .pdf-loaded { display: flex; align-items: center; gap: 0.75rem; background: rgba(52,168,100,0.08); border: 1px solid rgba(52,168,100,0.25); border-radius: 8px; padding: 0.65rem 1rem; margin-bottom: 1.25rem; font-size: 0.83rem; color: #7ed6a0; }
  .pdf-loaded .pdf-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .pdf-remove { background: none; border: none; color: #e09090; cursor: pointer; font-size: 1rem; padding: 0; transition: var(--transition); }
  .pdf-remove:hover { color: #ff7070; }
  .textarea-fulltext { min-height: 130px; font-size: 0.82rem; }
  .process-status { font-size: 0.82rem; padding: 0.65rem 1rem; border-radius: 8px; margin-bottom: 1rem; display: none; }
  .process-status.loading { display: flex; align-items: center; gap: 0.5rem; background: rgba(30,64,128,0.3); border: 1px solid rgba(30,64,128,0.5); color: var(--text-secondary); }
  .process-status.success { display: block; background: rgba(52,168,100,0.15); border: 1px solid rgba(52,168,100,0.3); color: #7ed6a0; }
  .process-status.error { display: block; background: rgba(224,112,112,0.12); border: 1px solid rgba(224,112,112,0.3); color: #e09090; }
  .spinner { width: 14px; height: 14px; border: 2px solid var(--border-strong); border-top-color: var(--gold-400); border-radius: 50%; animation: spin 0.7s linear infinite; flex-shrink: 0; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .modal-footer { display: flex; gap: 0.75rem; justify-content: flex-end; margin-top: 1.75rem; padding-top: 1.5rem; border-top: 1px solid var(--border); flex-wrap: wrap; }
  .btn-primary { background: linear-gradient(135deg, var(--gold-400), var(--gold-300)); color: var(--navy-900); border: none; cursor: pointer; padding: 0.65rem 1.5rem; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-size: 0.88rem; font-weight: 600; transition: var(--transition); display: flex; align-items: center; gap: 0.4rem; }
  .btn-primary:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(201,168,76,0.35); }
  .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn-secondary { background: transparent; border: 1px solid var(--border); color: var(--text-secondary); cursor: pointer; padding: 0.65rem 1.2rem; border-radius: 8px; font-family: 'DM Sans', sans-serif; font-size: 0.88rem; transition: var(--transition); }
  .btn-secondary:hover { border-color: var(--border-strong); color: var(--text-primary); }
  .manual-toggle-btn { font-size: 0.78rem; color: var(--gold-400); background: none; border: none; cursor: pointer; font-family: 'DM Sans', sans-serif; padding: 0; text-decoration: underline; text-underline-offset: 3px; transition: var(--transition); }
  .manual-toggle-btn:hover { color: var(--gold-200); }
  .manual-form-section { display: none; margin-top: 1.25rem; }
  .manual-form-section.visible { display: block; }

  /* EXPORT MODAL */
  .export-steps { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 1.5rem; }
  .export-step { display: flex; gap: 1rem; align-items: flex-start; }
  .step-num { width: 28px; height: 28px; border-radius: 50%; background: rgba(201,168,76,0.15); border: 1px solid var(--border-strong); color: var(--gold-300); font-size: 0.8rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 0.1rem; }
  .step-text { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.6; }
  .step-text strong { color: var(--text-primary); }
