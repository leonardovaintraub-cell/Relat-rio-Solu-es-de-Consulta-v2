const STORAGE_KEY = 'rfb-portal-v3';

let cards = [];
let activeMonth = 'all';
let activeSubject = 'all';

// ===== INIT =====
window.addEventListener('DOMContentLoaded', () => {
  document.getElementById('api-key-input').value = localStorage.getItem('rfb_apikey') || '';
  if (EMBEDDED_CARDS) {
    // Modo somente leitura (versão exportada para Netlify)
    cards = EMBEDDED_CARDS;
    // Esconde botões de edição/adição no modo exportado
    document.querySelector('.btn-header.export').style.display = 'none';
    document.querySelector('.btn-header:last-child').style.display = 'none';
  } else {
    // Modo editor — carrega do localStorage
    try { cards = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch(e) { cards = []; }
  }
  renderAll();
});

function saveLocal() {
  if (EMBEDDED_CARDS) return; // não salva no modo exportado
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(cards)); }
  catch(e) { showToast('localStorage cheio. Exporte o site antes de adicionar mais SCs.', 'error'); }
}

function saveApiKey() {
  localStorage.setItem('rfb_apikey', document.getElementById('api-key-input').value.trim());
}

// ===== RENDER =====
function renderAll() {
  renderIndexPanel();
  renderSidebar();
  applyFilters();
  document.getElementById('total-count').textContent = cards.length;
}

function renderIndexPanel() {
  const tagsEl = document.getElementById('index-tags');
  const clearBtn = document.getElementById('index-clear-btn');
  tagsEl.innerHTML = '';
  const subjects = getSubjectCounts();
  const keys = Object.keys(subjects).sort();
  if (keys.length === 0) {
    tagsEl.innerHTML = '<span class="index-empty">Nenhum assunto cadastrado ainda.</span>';
    clearBtn.classList.remove('visible'); return;
  }
  keys.forEach(s => {
    const tag = document.createElement('button');
    tag.className = 'index-tag' + (activeSubject === s ? ' active' : '');
    tag.innerHTML = `${esc(s)} <span class="tag-count">${subjects[s]}</span>`;
    tag.onclick = () => toggleSubject(s);
    tagsEl.appendChild(tag);
  });
  clearBtn.classList.toggle('visible', activeSubject !== 'all');
}

function getSubjectCounts() {
  const s = {};
  cards.forEach(c => { if (c.assunto) s[c.assunto] = (s[c.assunto]||0)+1; });
  return s;
}

function toggleSubject(subject) { activeSubject = activeSubject===subject ? 'all' : subject; renderAll(); }
function clearSubjectFilter() { activeSubject='all'; renderAll(); }

function renderSidebar() {
  const months = {};
  cards.forEach(c => { if (c.mes) months[c.mes] = (months[c.mes]||0)+1; });
  const ml = document.getElementById('month-list');
  document.getElementById('count-all').textContent = cards.length;
  ml.querySelectorAll('[data-month]:not([data-month="all"])').forEach(e => e.remove());
  Object.keys(months).sort((a,b)=>mkSort(b)-mkSort(a)).forEach(m => {
    const btn = document.createElement('button');
    btn.className = 'pill'+(activeMonth===m?' active':'');
    btn.dataset.month = m;
    btn.innerHTML = `${m} <span class="count">${months[m]}</span>`;
    btn.onclick = () => filterMonth(m, btn);
    ml.appendChild(btn);
  });
  const subjects = getSubjectCounts();
  const sl = document.getElementById('subject-list');
  sl.innerHTML = '';
  if (!Object.keys(subjects).length) { sl.innerHTML = '<div style="font-size:0.78rem;color:var(--text-muted);padding:0.5rem 0;">Nenhum assunto cadastrado.</div>'; return; }
  const ab = document.createElement('button');
  ab.className = 'subject-item'+(activeSubject==='all'?' active':'');
  ab.innerHTML = `Todos <span class="count">${cards.length}</span>`;
  ab.onclick = () => { activeSubject='all'; renderAll(); };
  sl.appendChild(ab);
  Object.keys(subjects).sort().forEach(s => {
    const btn = document.createElement('button');
    btn.className = 'subject-item'+(activeSubject===s?' active':'');
    btn.innerHTML = `<span>${esc(s)}</span> <span class="count">${subjects[s]}</span>`;
    btn.onclick = () => toggleSubject(s);
    sl.appendChild(btn);
  });
}

function mkSort(mes) {
  const ms=['janeiro','fevereiro','março','abril','maio','junho','julho','agosto','setembro','outubro','novembro','dezembro'];
  if (!mes) return 0;
  const p=mes.toLowerCase().split(' ');
  return (parseInt(p[1])||2000)*100+ms.indexOf(p[0]);
}

function filterMonth(month, btn) {
  activeMonth=month;
  document.querySelectorAll('[data-month]').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  applyFilters();
}

function applyFilters() {
  const q = document.getElementById('search-input').value.toLowerCase();
  let f = cards.filter(c => {
    const mm = activeMonth==='all'||c.mes===activeMonth;
    const ms = activeSubject==='all'||c.assunto===activeSubject;
    const mq = !q||[c.numero,c.assunto,c.ementa,c.resumo].some(v=>v&&v.toLowerCase().includes(q));
    return mm&&ms&&mq;
  });
  f.sort((a,b)=>pd(b.dataPublicacao)-pd(a.dataPublicacao));
  const te=document.getElementById('section-title'), tg=document.getElementById('active-filter-tag');
  if (activeSubject!=='all') { te.textContent=activeSubject; tg.textContent=activeMonth!=='all'?activeMonth:''; tg.style.display=activeMonth!=='all'?'':'none'; }
  else if (activeMonth!=='all') { te.textContent=activeMonth; tg.style.display='none'; }
  else { te.textContent='Todas as Soluções de Consulta'; tg.style.display='none'; }
  document.getElementById('result-count').textContent=`${f.length} resultado(s)`;
  renderCards(f);
}

function pd(str) {
  if (!str) return 0;
  const p=str.split('/');
  return p.length===3?new Date(p[2],p[1]-1,p[0]).getTime():0;
}

// ===== RENDER CARDS =====
const isReadOnly = () => !!EMBEDDED_CARDS;

function renderCards(list) {
  const grid = document.getElementById('cards-grid');
  grid.innerHTML = '';
  if (!list.length) { grid.innerHTML = `<div class="empty-state"><div class="icon">📋</div><h3>Nenhum resultado encontrado</h3><p>Tente ajustar os filtros ou a busca.</p></div>`; return; }
  list.forEach((c,i) => {
    const card = document.createElement('div');
    card.className = 'card';
    card.style.animationDelay = Math.min(i*0.05,0.3)+'s';
    const eid = 'em-'+c.id;
    const pdfBtn = c.pdfData ? `<a class="card-pdf-link" href="${c.pdfData}" target="_blank">📄 Ver PDF</a>` : '';
    const ajs = (c.assunto||'').replace(/\\/g,'\\\\').replace(/'/g,"\\'");
    const ijs = c.id.replace(/'/g,"\\'");
    const editBtns = isReadOnly() ? '' : `<button class="btn-card-action edit" onclick="openEditModal('${ijs}')">✏️ Editar</button><button class="btn-card-action danger" onclick="deleteCard('${ijs}')">🗑</button>`;
    card.innerHTML = `
      <div class="card-header">
        <div class="card-number">${esc(c.numero)}<span>${esc(c.dataPublicacao)}${c.mes?' · '+esc(c.mes):''}</span></div>
        <span class="card-badge" onclick="toggleSubject('${ajs}')" title="Filtrar por este assunto">${esc(c.assunto)}</span>
      </div>
      <p class="card-ementa collapsed" id="${eid}">${esc(c.ementa)}</p>
      <button class="toggle-ementa" onclick="toggleEmenta('${eid}',this)">Ver ementa completa ▾</button>
      <div class="card-divider"></div>
      <div><div class="card-resumo-label">Resumo</div><p class="card-resumo">${esc(c.resumo)}</p></div>
      <div class="card-footer">
        <div class="card-footer-left">${pdfBtn}</div>
        <div class="card-footer-right">${editBtns}</div>
      </div>`;
    grid.appendChild(card);
  });
}

function toggleEmenta(id, btn) {
  const el=document.getElementById(id);
  el.classList.toggle('collapsed');
  btn.textContent=el.classList.contains('collapsed')?'Ver ementa completa ▾':'Recolher ▴';
}

function deleteCard(id) {
  if (!confirm('Excluir esta solução de consulta?')) return;
  cards=cards.filter(c=>c.id!==id);
  saveLocal(); renderAll();
  showToast('Excluída com sucesso.','success');
}

function esc(str) {
  if (!str) return '';
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ===== MODALS =====
function openModal(id) { document.getElementById(id).classList.add('open'); document.body.style.overflow='hidden'; }
function closeModal(id) { document.getElementById(id).classList.remove('open'); document.body.style.overflow=''; }
function closeOnBg(e,id) { if(e.target===document.getElementById(id)) closeModal(id); }
document.addEventListener('keydown', e => { if(e.key==='Escape') ['modal-add','modal-edit','modal-export'].forEach(closeModal); });

// ===== MODAL ADICIONAR =====
function openAddModal() {
  document.getElementById('fulltext-input').value='';
  setStatus('','');
  removePdf('add');
  if(manualOpen) toggleManualForm();
  openModal('modal-add');
}

function toggleAccordion() {
  document.getElementById('api-accord-btn').classList.toggle('open');
  document.getElementById('api-accord-body').classList.toggle('open');
}
function toggleKeyVis() {
  const inp=document.getElementById('api-key-input');
  inp.type=inp.type==='password'?'text':'password';
}

let manualOpen=false;
function toggleManualForm() {
  manualOpen=!manualOpen;
  document.getElementById('manual-form').classList.toggle('visible',manualOpen);
  document.getElementById('btn-process').style.display=manualOpen?'none':'';
  document.getElementById('btn-save-manual').style.display=manualOpen?'':'none';
  document.getElementById('manual-toggle-btn').textContent=manualOpen?'← Usar extração automática':'✏️ Preencher manualmente';
