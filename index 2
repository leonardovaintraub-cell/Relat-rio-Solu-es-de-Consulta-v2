function saveManual() {
  const card={
    id: Date.now().toString(),
    numero: document.getElementById('f-numero').value.trim(),
    dataPublicacao: document.getElementById('f-data').value.trim(),
    mes: document.getElementById('f-mes').value.trim(),
    assunto: document.getElementById('f-assunto').value.trim(),
    ementa: document.getElementById('f-ementa').value.trim(),
    resumo: document.getElementById('f-resumo').value.trim(),
    pdfData: pdfState.add.dataUrl||null
  };
  if (!card.numero||!card.assunto) { showToast('Preencha ao menos número e assunto.','error'); return; }
  cards.unshift(card);
  saveLocal(); renderAll();
  closeModal('modal-add');
  showToast('Solução de consulta adicionada!','success');
}

// ===== MODAL EDITAR =====
function openEditModal(id) {
  const c=cards.find(x=>x.id===id);
  if (!c) return;
  document.getElementById('e-id').value=id;
  document.getElementById('e-numero').value=c.numero||'';
  document.getElementById('e-data').value=c.dataPublicacao||'';
  document.getElementById('e-mes').value=c.mes||'';
  document.getElementById('e-assunto').value=c.assunto||'';
  document.getElementById('e-ementa').value=c.ementa||'';
  document.getElementById('e-resumo').value=c.resumo||'';
  removePdf('edit');
  if (c.pdfData) {
    pdfState.edit.dataUrl=c.pdfData;
    pdfState.edit.base64=c.pdfData.split(',')[1];
    document.getElementById('edit-pdf-zone').style.display='none';
    document.getElementById('edit-pdf-info').style.display='flex';
    document.getElementById('edit-pdf-name').textContent='PDF já anexado (✕ para remover)';
  }
  openModal('modal-edit');
}

function saveEdit() {
  const id=document.getElementById('e-id').value;
  const idx=cards.findIndex(x=>x.id===id);
  if (idx===-1) return;
  cards[idx]={
    ...cards[idx],
    numero: document.getElementById('e-numero').value.trim(),
    dataPublicacao: document.getElementById('e-data').value.trim(),
    mes: document.getElementById('e-mes').value.trim(),
    assunto: document.getElementById('e-assunto').value.trim(),
    ementa: document.getElementById('e-ementa').value.trim(),
    resumo: document.getElementById('e-resumo').value.trim(),
    pdfData: pdfState.edit.dataUrl!==undefined ? pdfState.edit.dataUrl : cards[idx].pdfData
  };
  saveLocal(); renderAll();
  closeModal('modal-edit');
  showToast('Card atualizado!','success');
}

// ===== MODAL EXPORTAR =====
function openExportModal() { openModal('modal-export'); }

function downloadPublishable() {
  if (!cards.length) { showToast('Adicione ao menos uma SC antes de exportar.','error'); return; }
  showToast('Gerando arquivo...','success');

  // Pega o HTML atual desta página e substitui EMBEDDED_CARDS pelo JSON real
  const html = document.documentElement.outerHTML;
  const cardsJson = JSON.stringify(cards);
  // Substitui a linha const EMBEDDED_CARDS = null pelo array real
  const exported = html.replace(
    'const EMBEDDED_CARDS = null; // substituído no export',
    `const EMBEDDED_CARDS = ${cardsJson};`
  );

  const blob = new Blob([exported], { type: 'text/html;charset=utf-8' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'index.html';
  a.click();
  URL.revokeObjectURL(a.href);
  closeModal('modal-export');
  showToast('index.html baixado! Siga os passos do GitHub Pages para publicar.','success');
}

// ===== PDF =====
const pdfState = {
  add: { base64:null, dataUrl:null, name:null },
  edit: { base64:null, dataUrl:null, name:null }
};
function onDragOver(e,ctx) { e.preventDefault(); document.getElementById(ctx==='add'?'pdf-upload-zone':'edit-pdf-zone').classList.add('dragover'); }
function onDragLeave(ctx) { document.getElementById(ctx==='add'?'pdf-upload-zone':'edit-pdf-zone').classList.remove('dragover'); }
function onDrop(e,ctx) { e.preventDefault(); onDragLeave(ctx); const f=e.dataTransfer.files[0]; f&&f.type==='application/pdf'?loadPdf(f,ctx):showToast('Apenas PDFs.','error'); }
function onFileChange(e,ctx) { e.target.files[0]&&loadPdf(e.target.files[0],ctx); }
function loadPdf(file,ctx) {
  const r=new FileReader();
  r.onload=ev=>{
    pdfState[ctx].dataUrl=ev.target.result;
    pdfState[ctx].base64=ev.target.result.split(',')[1];
    pdfState[ctx].name=file.name;
    const z=ctx==='add'?'pdf-upload-zone':'edit-pdf-zone';
    const i=ctx==='add'?'pdf-loaded-info':'edit-pdf-info';
    const n=ctx==='add'?'pdf-loaded-name':'edit-pdf-name';
    document.getElementById(z).style.display='none';
    document.getElementById(i).style.display='flex';
    document.getElementById(n).textContent=file.name;
  };
  r.readAsDataURL(file);
}
function removePdf(ctx) {
  pdfState[ctx]={ base64:null, dataUrl:null, name:null };
  const z=ctx==='add'?'pdf-upload-zone':'edit-pdf-zone';
  const i=ctx==='add'?'pdf-loaded-info':'edit-pdf-info';
  const fi=ctx==='add'?'pdf-file-input':'edit-pdf-input';
  document.getElementById(z).style.display='';
  document.getElementById(i).style.display='none';
  document.getElementById(fi).value='';
}

// ===== PROCESS WITH AI =====
async function processar() {
  const text=document.getElementById('fulltext-input').value.trim();
  const hasPdf=!!pdfState.add.base64;
  if (!hasPdf&&!text) { showToast('Anexe um PDF ou cole o inteiro teor.','error'); return; }
  const apiKey=document.getElementById('api-key-input').value.trim();
  if (!apiKey) { showToast('Informe a API Key.','error'); if(!document.getElementById('api-accord-body').classList.contains('open')) toggleAccordion(); return; }
  setStatus('loading', hasPdf?'Lendo PDF com IA...':'Processando com IA...');
  document.getElementById('btn-process').disabled=true;
  const prompt=`Extraia do documento um JSON com exatamente estes campos:
- "numero": número da solução de consulta (ex: "SC Cosit nº 123/2025")
- "dataPublicacao": data de publicação no formato DD/MM/AAAA
- "mes": mês e ano por extenso em português (ex: "Março 2025")
- "assunto": tema principal em poucas palavras (ex: "IRPJ – Deduções")
- "ementa": ementa oficial do documento, copiada integralmente
- "resumo": parágrafo de 3 a 5 linhas explicando o contexto fático e a conclusão da RFB`;
  const uc=hasPdf?[{type:'document',source:{type:'base64',media_type:'application/pdf',data:pdfState.add.base64}},{type:'text',text:prompt}]:`${prompt}\n\nTexto:\n${text}`;
  try {
    const resp=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','x-api-key':apiKey,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:'Você é um assistente jurídico tributário especializado em soluções de consulta da RFB. Retorne APENAS um JSON válido, sem markdown.',messages:[{role:'user',content:uc}]})});
    const data=await resp.json();
    if (!resp.ok) throw new Error(data.error?.message||'Erro na API');
    let parsed;
    try { parsed=JSON.parse(data.content.map(b=>b.text||'').join('').replace(/```json|```/g,'').trim()); }
    catch(e) { throw new Error('Resposta inválida. Use o preenchimento manual.'); }
    if (!parsed.numero||!parsed.assunto) throw new Error('JSON incompleto. Use o preenchimento manual.');
    const card={id:Date.now().toString(),numero:parsed.numero||'',dataPublicacao:parsed.dataPublicacao||'',mes:parsed.mes||'',assunto:parsed.assunto||'',ementa:parsed.ementa||'',resumo:parsed.resumo||'',pdfData:pdfState.add.dataUrl||null};
    cards.unshift(card);
    saveLocal(); renderAll();
    setStatus('success','✅ Extraída e adicionada com sucesso!');
    setTimeout(()=>{ closeModal('modal-add'); showToast('Adicionada!','success'); },1200);
  } catch(err) {
    setStatus('error','⚠️ '+err.message);
    if (!manualOpen) toggleManualForm();
  } finally {
    document.getElementById('btn-process').disabled=false;
  }
}

function setStatus(type,msg) {
  const el=document.getElementById('process-status');
  el.className='process-status';
  el.innerHTML='';
  if (!type) return;
  el.classList.add(type);
  el.innerHTML=type==='loading'?`<div class="spinner"></div>${msg}`:msg;
}

let toastTimer;
function showToast(msg,type='success') {
  const t=document.getElementById('toast');
  t.textContent=(type==='success'?'✅ ':'⚠️ ')+msg;
  t.className='toast '+type+' show';
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>t.classList.remove('show'),4000);
}
</script>


